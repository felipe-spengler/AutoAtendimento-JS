    "build": "electron-builder"
  },
  "dependencies": {
    "body-parser": "^1.20.0",
    "express": "^4.18.0",
    "mqtt": "^5.15.1",
    "mysql2": "^3.0.0"
  },
  "devDependencies": {
    "concurrently": "^6.0.0",
    "electron": "^25.0.0",
    "electron-builder": "^25.1.8"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Aplicativo de Autoatendimento utilizando Electron",
  "build": {
    "appId": "com.motelinteligente.id",
    "productName": "AutoAtendimento",
    "files": [
      "**/*"
    ],
    "mac": {
      "target": "dmg"
